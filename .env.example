# Nillad dashboard — environment template. Copy to `.env` and fill in.
# The real `.env` is gitignored; never commit secrets.

# Secret used to sign the session cookie (any long random string).
NF_SESSION_SECRET=

# Ollama model the chat agent runs (must be pulled in Ollama). Optional —
# docker-compose defaults this to gemma4:12b-it-qat.
NILLAD_OLLAMA_MODEL=gemma4:12b-it-qat

# These have working defaults in docker-compose.yml; override only if your
# topology differs:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
#   NILLAD_DB=/vault/nillad.db
#   N8N_SEND_SMS_WEBHOOK=http://host.docker.internal:5678/webhook/nillad-send-sms
#   NILLAD_VAULT=/path/to/your/vault   # host dir bind-mounted to /vault (holds nillad.db)

# Invoice letterhead — business names + contact details. Code falls back to
# generic placeholders if unset, so the public repo never carries real info.
NILLAD_BIZ_TPS=
NILLAD_BIZ_SHARPLINE=
NILLAD_BIZ_ADDRESS=
NILLAD_BIZ_PHONE=
NILLAD_BIZ_EMAIL=
NILLAD_BIZ_VENMO=
